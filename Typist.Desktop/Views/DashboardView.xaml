<UserControl x:Class="Typist.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Typist.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="960">

            <!-- Header -->
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
            <TextBlock Text="Your typing performance at a glance." FontSize="14"
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,32"/>

            <!-- Stats Cards Row -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Best WPM -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="BEST WPM" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentCyan}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding BestWpm, StringFormat='{}{0:F0}'}" FontSize="40" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Words per minute" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Avg WPM -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,0,6,0">
                    <StackPanel>
                        <TextBlock Text="AVERAGE WPM" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentViolet}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding AverageWpm, StringFormat='{}{0:F1}'}" FontSize="40" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Words per minute" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Accuracy -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="6,0,6,0">
                    <StackPanel>
                        <TextBlock Text="ACCURACY" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentGreen}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding AverageAccuracy, StringFormat='{}{0:F1}%'}" FontSize="40" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Avg accuracy" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Tests -->
                <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="TESTS TAKEN" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentOrange}" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalTests}" FontSize="40" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Completed tests" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Lesson Progress Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,32">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="LESSON PROGRESS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentCyan}" Margin="0,0,0,8"/>
                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,0,12">
                            <Run Text="{Binding LessonsCompleted, Mode=OneWay}"/>
                            <Run Text=" of "/>
                            <Run Text="{Binding TotalLessons, Mode=OneWay}"/>
                            <Run Text=" lessons completed"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding LessonProgress}" Minimum="0" Maximum="100"
                                     Height="8" Style="{StaticResource ModernProgressBar}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Go to Lessons &#x2192;" Style="{StaticResource PrimaryButton}"
                            Command="{Binding GoToLessonsCommand}" Margin="24,0,0,0"/>
                </Grid>
            </Border>

            <!-- Quick Actions -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Quick Test button -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding StartQuickTestCommand}"/>
                    </Border.InputBindings>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x26A1;" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center" FontFamily="Segoe UI Symbol" Foreground="{StaticResource AccentCyan}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Quick Test" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Start a timed typing test now" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Lesson button -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding GoToLessonsCommand}"/>
                    </Border.InputBindings>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F4DA;" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center" FontFamily="Segoe UI Symbol" Foreground="{StaticResource AccentViolet}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Practice Lessons" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Structured exercises to improve" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Results -->
            <TextBlock Text="Recent Tests" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>

            <!-- Empty state -->
            <Border Style="{StaticResource CardStyle}"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" Margin="0,24">
                    <TextBlock Text="&#x1F3AF;" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12" FontFamily="Segoe UI Symbol" Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Text="No tests yet" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Complete your first test to see results here." FontSize="13"
                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Results list -->
            <Border Style="{StaticResource CardStyle}"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter},
                                         ConverterParameter=Invert}">
                <ListView ItemsSource="{Binding RecentResults}" Background="Transparent"
                          BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="4,6"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Hover1}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface2}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Date" Width="140"
                                            DisplayMemberBinding="{Binding CompletedAt, StringFormat='{}{0:MMM dd, HH:mm}'}"/>
                            <GridViewColumn Header="WPM" Width="80"
                                            DisplayMemberBinding="{Binding Wpm, StringFormat='{}{0:F0}'}"/>
                            <GridViewColumn Header="Raw WPM" Width="90"
                                            DisplayMemberBinding="{Binding RawWpm, StringFormat='{}{0:F0}'}"/>
                            <GridViewColumn Header="Accuracy" Width="90"
                                            DisplayMemberBinding="{Binding Accuracy, StringFormat='{}{0:F1}%'}"/>
                            <GridViewColumn Header="Duration" Width="90"
                                            DisplayMemberBinding="{Binding DurationSeconds, StringFormat='{}{0}s'}"/>
                            <GridViewColumn Header="Type" Width="100"
                                            DisplayMemberBinding="{Binding TestType}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
