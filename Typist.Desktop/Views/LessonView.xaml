<UserControl x:Class="Typist.Desktop.Views.LessonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Typist.Desktop.ViewModels"
             xmlns:helpers="clr-namespace:Typist.Desktop.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:LessonViewModel}"
             Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- === LEFT: Lesson List === -->
        <Border Background="{StaticResource Surface1}" BorderBrush="{StaticResource Border1}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Filters -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,12">
                    <TextBlock Text="Lessons" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                    <TextBlock Text="Difficulty" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Difficulties}"
                              SelectedItem="{Binding SelectedDifficulty}"
                              Style="{StaticResource ModernComboBox}" Margin="0,0,0,12"/>

                    <TextBlock Text="Category" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Style="{StaticResource ModernComboBox}"/>
                </StackPanel>

                <!-- Lesson list -->
                <ListBox ItemsSource="{Binding Lessons}"
                         SelectedItem="{Binding SelectedLesson}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="16,10"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="LessonItem_Click"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentCyanAlpha}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Hover1}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <Border Background="{StaticResource AccentCyanAlpha}" CornerRadius="3"
                                            Padding="5,1" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Difficulty}" FontSize="10"
                                                   Foreground="{StaticResource AccentCyan}"/>
                                    </Border>
                                    <Border Background="{StaticResource Hover1}" CornerRadius="3" Padding="5,1">
                                        <TextBlock Text="{Binding Category}" FontSize="10"
                                                   Foreground="{StaticResource TextSecondary}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- === RIGHT: Lesson Detail & Typing === -->
        <Grid Grid.Column="1">
            <!-- No lesson selected placeholder -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding SelectedLesson, Converter={StaticResource NullToVisibilityConverter},
                                             ConverterParameter=Invert}">
                <TextBlock Text="&#x1F4D6;" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16" FontFamily="Segoe UI Symbol" Foreground="{StaticResource AccentViolet}"/>
                <TextBlock Text="Select a lesson to get started" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Lesson detail -->
            <Grid Visibility="{Binding SelectedLesson, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="{StaticResource Surface1}"
                        BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1" Padding="32,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedLesson.Title}" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="{Binding SelectedLesson.Description}" FontSize="13"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Start Lesson" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding StartLessonCommand}"
                                    Visibility="{Binding IsTyping, Converter={StaticResource BoolToVisibilityConverter},
                                                         ConverterParameter=Invert}"/>
                            <Button Content="&#x21BA; Retry" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ResetLessonCommand}" Margin="8,0,0,0"
                                    Visibility="{Binding IsTyping, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Typing Area -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24">
                    <StackPanel>
                        <!-- Status Message -->
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13" Margin="0,0,0,16"
                                   Foreground="{StaticResource AccentCyan}"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>

                        <!-- Character Display -->
                        <Border Background="{StaticResource Surface1}" CornerRadius="12"
                                Padding="24,20" Margin="0,0,0,24"
                                Visibility="{Binding SelectedLesson, Converter={StaticResource NullToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding CharItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,2" Padding="0,0,0,2" Margin="0,2"
                                                BorderBrush="{Binding IsCurrent, Converter={StaticResource BoolToCursorBrushConverter}}">
                                            <TextBlock Text="{Binding Character}" FontSize="20" FontFamily="Consolas"
                                                       Foreground="{Binding State, Converter={StaticResource CharStateToColorConverter}}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Stats Bar -->
                <Border Grid.Row="2" Background="{StaticResource Surface1}"
                        BorderBrush="{StaticResource Border1}" BorderThickness="0,1,0,0"
                        Padding="32,14"
                        Visibility="{Binding IsTyping, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,40,0">
                            <TextBlock Text="WPM" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentCyan}"/>
                            <TextBlock Text="{Binding CurrentWpm, StringFormat='{}{0:F0}'}" FontSize="24"
                                       FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,40,0">
                            <TextBlock Text="ACCURACY" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGreen}"/>
                            <TextBlock Text="{Binding CurrentAccuracy, StringFormat='{}{0:F1}%'}" FontSize="24"
                                       FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="PROGRESS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}">
                                <Run Text="{Binding CurrentIndex, Mode=OneWay}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding SelectedLesson.Content.Length, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
