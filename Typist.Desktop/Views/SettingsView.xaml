<UserControl x:Class="Typist.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Typist.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             Background="Transparent">

    <StackPanel Margin="32" MaxWidth="560">

        <!-- Header -->
        <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
        <TextBlock Text="Manage your profile and application data." FontSize="14"
                   Foreground="{StaticResource TextSecondary}" Margin="0,0,0,32"/>

        <!-- Profile Card -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="PROFILE" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentCyan}" Margin="0,0,0,16"/>

                <TextBlock Text="Username" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" Margin="0,0,12,0"/>
                    <Button Grid.Column="1" Content="Save" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveUsernameCommand}"/>
                </Grid>

                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Margin="0,12,0,0"
                           Visibility="{Binding StatusMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsStatusError}" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Data Management Card -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="DATA MANAGEMENT" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentRed}" Margin="0,0,0,16"/>

                <TextBlock FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,16"
                           TextWrapping="Wrap">
                    Clearing your data will permanently delete all test results and lesson progress.
                    This action cannot be undone.
                </TextBlock>

                <Button Content="ðŸ—‘  Clear All Data" Style="{StaticResource DangerButton}"
                        Command="{Binding ClearAllDataCommand}"/>
            </StackPanel>
        </Border>

        <!-- App Info -->
        <Border Style="{StaticResource CardStyle}" Margin="0,20,0,0">
            <StackPanel>
                <TextBlock Text="ABOUT" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,12"/>
                <TextBlock Text="Typist" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="A modern typing tutorial and speed test application."
                           FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                <TextBlock Text="Version 1.0.0" FontSize="12"
                           Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>

